# Adloom environment — copy to .env and fill in. NEVER commit .env.

# Google AI Studio key for Gemini image generation (https://aistudio.google.com/apikey)
GKEY=

# Optional: explicit Chrome/Chromium path for the HTML compositor renderer.
# Leave blank to auto-detect common install locations.
CHROME_PATH=

# Metricool scheduling (via the Metricool MCP server, not these env vars) —
# the MCP handles auth. Kept here only as a reminder of what you connect:
#   MCP server URL: https://ai.metricool.com/mcp
#   Your brand id (blogId) is read at runtime via the getBrandSettings tool.
